# =========================================================================
# WhatsChat Secure Cloud Engine - Environment Variables Configuration
# Copy this file to a new file named '.env' and fill in your details.
# When deploying to Heroku, define these variables in the App Settings Config Vars.
# =========================================================================

# The port where your secure Node.js server will run (Heroku injects this automatically)
PORT=5000

# Connection string for your MongoDB database.
# For Local: mongodb://127.0.0.1:27017/whatschat (or mongodb://localhost:27017/whatschat)
# For Production (MongoDB Atlas / Heroku): mongodb+srv://<username>:<password>@cluster.mongodb.net/whatschat?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/whatschat

# Optional node environment configuration (production or development)
NODE_ENV=production
